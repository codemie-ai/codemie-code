{
  "description": "CodeMie session tracking hooks - unified command handler",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "codemie sound SessionStart"
          },
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/rtk-baseline.sh"
          }
        ]
      },
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/handoff-session-resume.sh"
          }
        ]
      },
      {
        "matcher": "compact|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/cbm-session-reminder.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "codemie sound PermissionRequest"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "codemie sound Stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "codemie sound UserPromptSubmit"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codemie hook",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/handoff-precompact.sh",
            "timeout": 90
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/cbm-mcp-marker.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/bash-ban-raw-tools.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Read|Search",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codemie/claude-plugin/scripts/bash/cbm-code-discovery-gate.sh"
          }
        ]
      }
    ]
  }
}